      "medio":   { "min_min": 15, "max_min": 30, "palavras": 3000,  "cenas_aprox": 180 },
      "longo":   { "min_min": 30, "max_min": 60, "palavras": 6000,  "cenas_aprox": 360 },
      "maraton": { "min_min": 60, "max_min": 90, "palavras": 10000, "cenas_aprox": 600 }
    },
    "rotacao_janela": 3
  },

  "layers_allowed": {
    "_doc": "Quais opções (A-L) de cada camada são permitidas neste canal. Lista vazia = todas.",
    "D01_HOOK":         ["A", "C", "E", "K"],
    "D02_PERSPECTIVA":  ["A", "B", "F"],
    "D03_ARQUITETURA":  ["A", "C", "H", "K"],
    "D04_TOM":          ["B", "I", "L"],
    "D05_ARCO":         ["B", "E", "F", "J"],
    "D06_MOTOR":        ["A", "E", "G", "I"],
    "D07_RITMO":        ["B", "D", "G"],
    "D08_ANALOGIA":     ["A", "C", "K", "L"],
    "D09_TEMPORAL":     [],
    "D10_STAKES":       [],
    "D11_PROVA":        [],
    "D12_TECNICA":      [],
    "D13_FECHAMENTO":   [],
    "D14_DISPOSITIVO":  []
  },

  "anti_repeticao": {
    "_doc": "Camadas que NUNCA podem repetir vs histórico do canal. Ordem de prioridade.",
    "obrigatorias": ["D05_ARCO", "D03_ARQUITETURA", "D01_HOOK"],
    "janela_max_distance": 10
  }
}
