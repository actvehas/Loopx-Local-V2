{
  "_doc": "DNA do canal — define quais combos da Narrative Forge são PERMITIDOS pra este canal. Editar manualmente. Cópia em Obsidian/Projetos/Meus Canais/{Canal}/forge-dna.json",

  "canal": "X",
  "nome": "Nome do Canal",

  "filtros_locked": {
    "_doc": "Filtros que NUNCA mudam neste canal",
